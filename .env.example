# Host port that Cardboard listens on
PORT=8000

# Where the database and media files are stored on the host.
# Change this to an absolute path if you want data stored somewhere specific,
# e.g. /home/user/cardboard-data or /mnt/user/appdata/cardboard (Unraid).
DATA_PATH=./data

# CORS — restrict to your domain in production, e.g. https://cardboard.example.com
# ALLOWED_ORIGINS=*
